# auth-hub config
#
# Copy to config.toml and edit. Run: ./auth-hub -config config.toml

# Where auth-hub listens. Defaults to ":9090".
listen = ":9090"

# The secret Dragonite must send. Put this exact value in Dragonite's
# remote_auth_secret. auth-hub checks it, then replaces it with the matching
# upstream's own secret before forwarding.
secret = "pick-a-long-random-string"

[log]
# debug, info, warn or error. Defaults to "info".
#
# Unlike everything else here, the level applies on reload without a restart —
# so you can turn debug on while something is going wrong and back off after,
# without dropping auth. debug adds which upstream each try went to, and the
# requests that were rejected (wrong path, wrong method, wrong secret).
level = "info"

# text or json. Defaults to "text". Use json if something downstream is doing
# the reading; text is easier if that something is you.
format = "text"

# Also append every line to logs/auth-hub-YYYY-MM-DD.log, next to the binary.
# Off by default. stdout and stderr keep everything either way, so
# `docker compose logs` doesn't go quiet when you turn this on.
#
# The date in the name is the rotation: a new file each day, nothing to
# configure, and old days are just files you can delete. In Docker they land in
# /logs and go when the container does — mount a volume there to keep them.
save_to_file = false

# One [[pool]] per account provider type. Dragonite's remote_auth_url points at
# listen + path. Requests round robin across that pool's upstreams.
#
#   [auth.ptc]
#   remote_auth_url = "http://auth-hub:9090/ptc"
#   remote_auth_secret = "pick-a-long-random-string"
#
# A pool per provider, rather than one big rotation, because the login URL
# Dragonite sends is provider specific: a PTC auth server can't service a Google
# login. Only ptc and g use remote auth at all — nk authenticates on its own and
# never calls out here. The path is auth-hub's own, so name it whatever you like
# as long as Dragonite points at it.

[[pool]]
path = "/ptc"

  [[pool.upstream]]
  # Full URL of the real auth server endpoint, exactly what you'd have put in
  # Dragonite's remote_auth_url before.
  url = "http://auth-1:5090/api/v1/login-code"
  # That upstream's own secret. Omit if it doesn't check one.
  secret = "auth-1-secret"
  # Share of the traffic, relative to the other upstreams in this pool.
  # Defaults to 1, so leave it out and everything splits evenly. Here auth-1
  # takes 3 logins for every 1 auth-2 takes.
  weight = 3

  [[pool.upstream]]
  url = "http://auth-2:5090/api/v1/login-code"
  secret = "auth-2-secret"
  weight = 1

# weight = 0 drains an upstream: it keeps its config but takes no traffic at
# all, not even as a failover target. Handy before restarting one. At least one
# upstream in a pool has to be above 0.
#
#   [[pool.upstream]]
#   url = "http://auth-3:5090/api/v1/login-code"
#   weight = 0

# A second pool for Google, if you use it. Dragonite calls that provider "g",
# so the section over there is [auth.g] — not [auth.google], which it rejects
# with "unknown auth provider".
#
#   [auth.g]
#   remote_auth_url = "http://auth-hub:9090/g"
#   remote_auth_secret = "pick-a-long-random-string"
#
# [[pool]]
# path = "/g"
#
#   [[pool.upstream]]
#   url = "http://google-auth-1:5090/api/v1/login-code"
#   secret = "google-auth-1-secret"
#
#   [[pool.upstream]]
#   url = "http://google-auth-2:5090/api/v1/login-code"
#   secret = "google-auth-2-secret"
